# Copy the Session pooler URI from Supabase's Connect panel.
# Replace [YOUR-PASSWORD] and keep sslmode=require at the end.
DATABASE_URL=postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Render supplies PORT automatically. This is only useful locally.
PORT=3000
